<!DOCTYPE html>
<html lang="sq">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TREGUAL-MVC</title>

    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
</head>

<body>

    <header class="main-header">
        <div class="header-container">
            <a class="logo" asp-area="" asp-controller="Home" asp-action="Index">TREGUAL-MVC</a>

            <div class="header-icons">
                <button class="btn">Sign up</button>
            </div>
        </div>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="main-footer">
        <div class="footer-container">
            <p>&copy; @DateTime.Now.Year - TREGUAL-MVC</p>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>